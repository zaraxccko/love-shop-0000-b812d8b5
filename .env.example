# ============================================================
# ROOT .env — для docker compose (фронт + прокси)
# Скопируй в .env и заполни.
# ============================================================

# --- Frontend (вкомпилируется в bundle на этапе build) ---
# Базовый URL API. На проде через Caddy: https://prxvt.ink/api
# Можно с /api в конце или без — фронт сам нормализует.
VITE_API_URL=https://prxvt.ink/api

# Telegram ID админов через запятую (fallback для UI).
# Дублируется на бэке в backend/.env → ADMIN_TG_IDS.
VITE_ADMIN_IDS=8044243116

# --- Postgres (используется сервисом postgres в docker-compose) ---
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=shopdb
