# URL вашего бэкенда (Fastify API).
# Можно указать с /api в конце или без — фронт сам нормализует.
# В dev: http://localhost:8080/api
# В prod (через Caddy):  https://prxvt.ink/api  (или просто https://prxvt.ink)
VITE_API_URL=http://localhost:8080/api

# Telegram ID администраторов через запятую — fallback для UI,
# чтобы кнопка "Admin" появлялась сразу, даже если бэк ещё не отдал isAdmin.
# На бэке whitelist дублируется в ADMIN_TG_IDS (.env backend).
VITE_ADMIN_IDS=123456789,987654321
