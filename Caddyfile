# ============================================================
# Edge reverse-proxy для любого домена из env.
# Caddy сам выпускает сертификат (ZeroSSL, затем Let's Encrypt fallback).
# Запускается как сервис `proxy` в docker-compose.
# ============================================================

{
	# Email для ACME-аккаунта (Let's Encrypt / ZeroSSL)
	email {$ACME_EMAIL:admin@localhost}

	# Сначала пробуем ZeroSSL (свой rate-limit, не связан с LE),
	# если не получится — fallback на Let's Encrypt.
	cert_issuer zerossl
	cert_issuer acme
}

{$APP_DOMAINS} {
	encode gzip zstd

	# API → backend
	handle /api/* {
		reverse_proxy api:3000
	}

	# Загрузки фото-подтверждений
	handle /uploads/* {
		reverse_proxy api:3000
	}

	# Всё остальное → фронт (SPA)
	handle {
		reverse_proxy frontend:80
	}

	log {
		output stdout
		format console
	}
}
